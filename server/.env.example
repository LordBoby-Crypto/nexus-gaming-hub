# Copy this file to .env and paste your API key after the equals sign.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
PORT=8787
FFMPEG_PATH=ffmpeg

# Comma-separated browser origins. GitHub Pages origin can be added later.
# Example: http://localhost:8787,https://lordboby-crypto.github.io
ALLOWED_ORIGINS=http://localhost:8787,http://127.0.0.1:8787
